# Database
DATABASE_URL=postgresql+asyncpg://forms:forms@forms-db:5432/forms
DATABASE_URL_SYNC=postgresql://forms:forms@forms-db:5432/forms

# Application
DEBUG=false
BASE_URL=https://rm.swhgrp.com

# Portal SSO
PORTAL_SECRET_KEY=your-portal-secret-key-here
SECRET_KEY=your-forms-secret-key-here

# Service URLs
PORTAL_SERVICE_URL=http://portal-app:8000
HR_SERVICE_URL=http://hr-app:8000
FILES_SERVICE_URL=http://files-app:8000

# File uploads
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg,doc,docx

# Email (optional - for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=forms@swhgrp.com
