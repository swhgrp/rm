{
  "ui:order": [
    "employee_name",
    "employee_id",
    "job_title",
    "department",
    "hire_date",
    "date_of_injury",
    "time_of_injury",
    "location_of_incident",
    "description_of_injury",
    "body_part",
    "body_part_other",
    "injury_type",
    "injury_type_other",
    "injury_severity",
    "activity_at_time",
    "equipment_involved",
    "witnesses",
    "medical_treatment",
    "medical_facility",
    "days_away",
    "days_restricted",
    "resulted_in_death",
    "supervisor_name",
    "supervisor_notified",
    "preventive_measures",
    "additional_notes"
  ],
  "employee_name": {
    "ui:autofocus": true,
    "ui:placeholder": "Enter employee's full name"
  },
  "date_of_injury": {
    "ui:widget": "date"
  },
  "hire_date": {
    "ui:widget": "date"
  },
  "time_of_injury": {
    "ui:widget": "time"
  },
  "description_of_injury": {
    "ui:widget": "textarea",
    "ui:options": {
      "rows": 4
    },
    "ui:placeholder": "Describe what happened in detail..."
  },
  "body_part_other": {
    "ui:widget": "hidden",
    "ui:options": {
      "showIf": {
        "body_part": "Other"
      }
    }
  },
  "injury_type_other": {
    "ui:widget": "hidden",
    "ui:options": {
      "showIf": {
        "injury_type": "Other"
      }
    }
  },
  "injury_severity": {
    "ui:widget": "range",
    "ui:help": "1 = Minor, 5 = Severe"
  },
  "activity_at_time": {
    "ui:widget": "textarea",
    "ui:options": {
      "rows": 3
    }
  },
  "medical_facility": {
    "ui:options": {
      "showIf": {
        "medical_treatment": ["Sent to clinic/urgent care", "Sent to emergency room", "Hospitalized"]
      }
    }
  },
  "days_away": {
    "ui:options": {
      "showIf": {
        "medical_treatment": ["Sent to clinic/urgent care", "Sent to emergency room", "Hospitalized"]
      }
    }
  },
  "days_restricted": {
    "ui:options": {
      "showIf": {
        "medical_treatment": ["Treated on-site", "Sent to clinic/urgent care", "Sent to emergency room"]
      }
    }
  },
  "resulted_in_death": {
    "ui:widget": "checkbox"
  },
  "supervisor_notified": {
    "ui:widget": "checkbox"
  },
  "preventive_measures": {
    "ui:widget": "textarea",
    "ui:options": {
      "rows": 3
    }
  },
  "additional_notes": {
    "ui:widget": "textarea",
    "ui:options": {
      "rows": 3
    }
  },
  "ui:groups": [
    {
      "title": "Employee Information",
      "fields": ["employee_name", "employee_id", "job_title", "department", "hire_date"]
    },
    {
      "title": "Incident Details",
      "fields": ["date_of_injury", "time_of_injury", "location_of_incident", "activity_at_time", "equipment_involved"]
    },
    {
      "title": "Injury Information",
      "fields": ["description_of_injury", "body_part", "body_part_other", "injury_type", "injury_type_other", "injury_severity"]
    },
    {
      "title": "Medical Treatment",
      "fields": ["medical_treatment", "medical_facility", "days_away", "days_restricted", "resulted_in_death"]
    },
    {
      "title": "Additional Information",
      "fields": ["witnesses", "supervisor_name", "supervisor_notified", "preventive_measures", "additional_notes"]
    }
  ]
}
