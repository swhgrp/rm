{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "First Report of Injury",
  "description": "OSHA compliant first report of workplace injury form",
  "required": [
    "employee_name",
    "date_of_injury",
    "time_of_injury",
    "location_of_incident",
    "description_of_injury",
    "body_part",
    "injury_type"
  ],
  "properties": {
    "employee_name": {
      "type": "string",
      "title": "Employee Name",
      "maxLength": 200
    },
    "employee_id": {
      "type": "string",
      "title": "Employee ID"
    },
    "job_title": {
      "type": "string",
      "title": "Job Title"
    },
    "department": {
      "type": "string",
      "title": "Department"
    },
    "hire_date": {
      "type": "string",
      "format": "date",
      "title": "Date of Hire"
    },
    "date_of_injury": {
      "type": "string",
      "format": "date",
      "title": "Date of Injury"
    },
    "time_of_injury": {
      "type": "string",
      "title": "Time of Injury",
      "pattern": "^([01]?[0-9]|2[0-3]):[0-5][0-9]$"
    },
    "location_of_incident": {
      "type": "string",
      "title": "Location of Incident",
      "maxLength": 500
    },
    "description_of_injury": {
      "type": "string",
      "title": "Description of Injury/Illness",
      "maxLength": 2000
    },
    "body_part": {
      "type": "string",
      "title": "Body Part Affected",
      "enum": [
        "Head",
        "Neck",
        "Shoulder",
        "Upper Arm",
        "Elbow",
        "Lower Arm",
        "Wrist",
        "Hand",
        "Finger",
        "Upper Back",
        "Lower Back",
        "Chest",
        "Abdomen",
        "Hip",
        "Upper Leg",
        "Knee",
        "Lower Leg",
        "Ankle",
        "Foot",
        "Toe",
        "Multiple Body Parts",
        "Other"
      ]
    },
    "body_part_other": {
      "type": "string",
      "title": "Other Body Part (if selected)"
    },
    "injury_type": {
      "type": "string",
      "title": "Type of Injury",
      "enum": [
        "Cut/Laceration",
        "Burn",
        "Sprain/Strain",
        "Fracture",
        "Bruise/Contusion",
        "Slip/Fall",
        "Repetitive Motion",
        "Chemical Exposure",
        "Eye Injury",
        "Hearing Loss",
        "Respiratory",
        "Other"
      ]
    },
    "injury_type_other": {
      "type": "string",
      "title": "Other Injury Type (if selected)"
    },
    "injury_severity": {
      "type": "integer",
      "title": "Injury Severity (1-5)",
      "minimum": 1,
      "maximum": 5,
      "default": 1
    },
    "activity_at_time": {
      "type": "string",
      "title": "What was employee doing at time of injury?",
      "maxLength": 1000
    },
    "equipment_involved": {
      "type": "string",
      "title": "Equipment/Tools/Substances Involved",
      "maxLength": 500
    },
    "witnesses": {
      "type": "string",
      "title": "Names of Witnesses (if any)",
      "maxLength": 500
    },
    "medical_treatment": {
      "type": "string",
      "title": "Medical Treatment",
      "enum": [
        "No treatment needed",
        "First aid only",
        "Treated on-site",
        "Sent to clinic/urgent care",
        "Sent to emergency room",
        "Hospitalized"
      ]
    },
    "medical_facility": {
      "type": "string",
      "title": "Medical Facility Name (if applicable)"
    },
    "days_away": {
      "type": "integer",
      "title": "Days Away from Work",
      "minimum": 0,
      "default": 0
    },
    "days_restricted": {
      "type": "integer",
      "title": "Days on Restricted Duty",
      "minimum": 0,
      "default": 0
    },
    "resulted_in_death": {
      "type": "boolean",
      "title": "Did injury result in death?",
      "default": false
    },
    "supervisor_name": {
      "type": "string",
      "title": "Supervisor Name"
    },
    "supervisor_notified": {
      "type": "boolean",
      "title": "Was supervisor notified?",
      "default": true
    },
    "preventive_measures": {
      "type": "string",
      "title": "What preventive measures could be taken?",
      "maxLength": 2000
    },
    "additional_notes": {
      "type": "string",
      "title": "Additional Notes",
      "maxLength": 2000
    }
  }
}
