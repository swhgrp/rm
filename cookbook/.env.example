# Cookbook AI System Configuration

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Database
DATABASE_URL=postgresql://cookbook_user:cookbook_pass@cookbook-db:5432/cookbook_db

# ChromaDB
