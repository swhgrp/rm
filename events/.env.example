# Database
DATABASE_URL=postgresql://events_user:events_password@events-db:5432/events_db

# Redis
REDIS_URL=redis://events-redis:6379/0

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# HR Integration
HR_API_URL=http://hr-app:8000/api
HR_API_KEY=your-hr-api-key

# Email
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
FROM_EMAIL=events@swhgrp.com
FROM_NAME=SW Hospitality Events

# Storage (S3-compatible)
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=swhgrp-events-documents
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_REGION=us-east-1

# hCaptcha
HCAPTCHA_SECRET=your-hcaptcha-secret
HCAPTCHA_SITEKEY=your-hcaptcha-sitekey

# Application
APP_NAME=SW Hospitality Events
APP_URL=https://rm.swhgrp.com/events
ENVIRONMENT=production
DEBUG=false
